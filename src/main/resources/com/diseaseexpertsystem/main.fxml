<AnchorPane maxHeight="464.0" maxWidth="818.0" minHeight="464.0" minWidth="818.0" prefHeight="464.0" prefWidth="818.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.diseaseexpertsystem.MainController">
